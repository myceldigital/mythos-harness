MYTHOS_ENV=development
MYTHOS_HOST=0.0.0.0
MYTHOS_PORT=8080
MYTHOS_MAX_LOOPS=6
MYTHOS_MODEL_BASE=base-reasoning
MYTHOS_MODEL_FAST=fast-triage
MYTHOS_MODEL_JUDGE=external-judge
MYTHOS_MODEL_CODE_MATH=code-math
MYTHOS_MODEL_STYLE=style-harmonizer

# Provider backend: local | openai_compatible | openrouter
MYTHOS_PROVIDER_BACKEND=local
MYTHOS_PROVIDER_API_KEY=
MYTHOS_PROVIDER_BASE_URL=https://api.openai.com/v1
MYTHOS_PROVIDER_TIMEOUT_S=60
MYTHOS_OPENROUTER_SITE_URL=https://your-app.example
MYTHOS_OPENROUTER_APP_NAME=mythos-harness

# Optional separate judge provider backend.
MYTHOS_JUDGE_PROVIDER_BACKEND=
MYTHOS_JUDGE_PROVIDER_API_KEY=
MYTHOS_JUDGE_PROVIDER_BASE_URL=

# API middleware hardening.
MYTHOS_API_AUTH_ENABLED=false
MYTHOS_API_AUTH_KEYS=
MYTHOS_API_AUTH_KEY_HASHES=
MYTHOS_RATE_LIMIT_ENABLED=false
MYTHOS_RATE_LIMIT_REQUESTS=60
MYTHOS_RATE_LIMIT_WINDOW_S=60
MYTHOS_RATE_LIMIT_KEY_SOURCE=api_key
MYTHOS_RATE_LIMIT_BACKEND=memory
MYTHOS_RATE_LIMIT_FAIL_OPEN=false
MYTHOS_REDIS_URL=
MYTHOS_REDIS_PREFIX=mythos

# Observability defaults.
MYTHOS_METRICS_ENABLED=true
MYTHOS_ACCESS_LOG_ENABLED=true
MYTHOS_REQUEST_ID_HEADER=x-request-id
MYTHOS_LOG_LEVEL=INFO

# Retry policy for external provider/store adapters.
MYTHOS_RETRY_MAX_ATTEMPTS=3
MYTHOS_RETRY_BASE_DELAY_S=0.25
MYTHOS_RETRY_MAX_DELAY_S=2.0
MYTHOS_RETRY_JITTER_S=0.05

# Storage backends:
# - session: memory | postgres
# - policy: file | http
# - trajectory: jsonl | postgres | http
MYTHOS_SESSION_STORE_BACKEND=memory
MYTHOS_POLICY_STORE_BACKEND=file
MYTHOS_TRAJECTORY_STORE_BACKEND=jsonl

# Externalized store settings.
MYTHOS_POSTGRES_DSN=
MYTHOS_POSTGRES_SCHEMA=mythos
MYTHOS_PGVECTOR_DIMENSIONS=1536
MYTHOS_POLICY_HTTP_URL=
MYTHOS_POLICY_HTTP_API_KEY=
MYTHOS_TRAJECTORY_HTTP_URL=
MYTHOS_TRAJECTORY_HTTP_API_KEY=

# Embedding backend for pgvector sessions: local | openai_compatible | openrouter
MYTHOS_EMBEDDING_BACKEND=local
MYTHOS_EMBEDDING_MODEL=text-embedding-3-small
MYTHOS_EMBEDDING_API_KEY=
MYTHOS_EMBEDDING_BASE_URL=
MYTHOS_EMBEDDING_TIMEOUT_S=45

# Similarity retrieval count for prelude memory injection.
MYTHOS_MEMORY_RETRIEVAL_K=3

MYTHOS_TRAJECTORY_STORE_PATH=data/trajectories.jsonl
MYTHOS_POLICY_PATH=config/policy_rules.json
